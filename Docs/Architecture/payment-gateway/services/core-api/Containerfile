# services/core-api/Containerfile
# Build context = repo root, so we can COPY shared/ into the image.
#   podman build -f services/core-api/Containerfile -t core-api .

FROM docker.io/library/python:3.12-slim AS runtime

# OS deps: ca-certs for HTTPS, that's it. No curl — health checks use python's
# urllib (declared in podman-compose.yml).
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Non-root user; rubric expects "no monolithic God-files / hardcoded secrets"
# and running as non-root is a basic hygiene win.
RUN useradd --create-home --shell /bin/bash app
WORKDIR /app

# Python config: no .pyc clutter, unbuffered stdout for live container logs.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app

# Install dependencies first (cache-friendly layer).
COPY services/core-api/requirements.txt /app/requirements.txt
RUN pip install -r /app/requirements.txt

# Copy shared lib + service code AFTER deps so a code edit doesn't bust the
# pip layer.
COPY shared /app/shared
COPY services/core-api/main.py /app/main.py
COPY services/core-api/app /app/app

USER app

EXPOSE 8000

# uvicorn worker count: 1 in dev (reload-friendly); production override via
# UVICORN_WORKERS env var if needed.
CMD ["python", "-m", "uvicorn", "main:app", \
     "--host", "0.0.0.0", "--port", "8000", \
     "--no-access-log", "--proxy-headers"]
